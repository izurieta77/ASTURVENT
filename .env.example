# Variables de entorno para Netlify Functions
# Copia este archivo como .env para desarrollo local (netlify dev)
# En producción, configúralas en: Netlify → Site settings → Environment variables

# OpenAI — usado por /.netlify/functions/ia, dvr-snapshot, dvr-daily-report
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Login server-side (auth.js)
AUTH_SECRET=cambiar-por-string-aleatorio-mayor-a-32-caracteres
ADMIN_PIN=000000
AGENT_PINS={"RIGO":"101","RAFAEL":"102"}
CLIENT_CODES={"TGIO":"TGIO2026"}

# ─── Agente DVR (monitoreo de tienda) ────────────────────────────────────
# DVR Hikvision accesible por IP pública o DDNS, con puerto HTTP/ISAPI abierto.
# El frontend NUNCA recibe estas credenciales — solo las usan los scheduled functions.
DVR_HOST=tienda.no-ip.org
DVR_PORT=80
DVR_USER=admin
DVR_PASS=
# Lista de cámaras a monitorear. ch = canal del DVR (entero), label = nombre legible.
DVR_CHANNELS=[{"ch":1,"label":"Entrada"},{"ch":2,"label":"Piso"},{"ch":3,"label":"Mostrador"},{"ch":4,"label":"Trastienda"}]

# Apps Script Web App (mismo deploy ya usado para despachos). Pegar la URL /exec.
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbz.../exec
# Token compartido entre las funciones y Apps Script para autorizar writes DVR.
APPS_SCRIPT_TOKEN=cambiar-por-string-aleatorio-largo
