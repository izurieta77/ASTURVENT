# Variables de entorno del sitio SUPER CHEAP (Netlify Functions).
# Copia este archivo como .env para desarrollo local (netlify dev).
# En produccion, configuralas en: Netlify -> Site settings -> Environment variables.

# --- Login del dashboard ---
# PIN para entrar al dashboard (ej. "1234"). Cambialo por algo solo tuyo.
SC_PIN=1234
# Secreto aleatorio >=32 caracteres para firmar los tokens de sesion.
AUTH_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria-de-32+

# --- Google BigQuery ---
# ID de tu proyecto de Google Cloud.
GCP_PROJECT_ID=mi-proyecto-gcp
# Dataset de BigQuery (por defecto: super_cheap).
BQ_DATASET=super_cheap
# Credenciales del Service Account en JSON, en UNA sola linea.
# (Pega aqui el contenido completo del archivo .json de la cuenta de servicio.)
GCP_SA_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# --- IA para leer tickets (OpenAI vision) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Sincronizacion desde SICAR (bridge local) ---
# Token compartido entre el bridge de tu PC y el endpoint sc-ingest.
# Debe ser el MISMO valor que pongas en sicar-bridge/config.json.
SICAR_INGEST_TOKEN=cambia-esto-por-un-token-secreto-largo
